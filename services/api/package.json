{
  "name": "@avelren/api",
  "version": "0.1.0",
  "private": true,
  "description": "Avelren API service",
  "type": "module",
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "cheerio": "1.0.0",
    "fastify": "^5.10.0",
    "firebase-admin": "^13.4.0",
    "google-auth-library": "^10.9.0",
    "ipaddr.js": "2.2.0",
    "pg": "^8.16.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.15.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
