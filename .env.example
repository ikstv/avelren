# Reserved for the future server-side collector. Never expose this to Android.
PUBLIC_SOURCE_URL=https://example.invalid/public-data

# Values below 60 must be rejected.
POLL_INTERVAL_SECONDS=60
POLL_TIMEOUT_SECONDS=15
THRESHOLD_STEP=50

# Local default is memory. Production must explicitly use postgres.
AVELREN_STORAGE_MODE=memory
# DATABASE_URL=postgresql://avelren:change-me@postgres.invalid:5432/avelren
# Use a unique non-secret identifier per server instance when wiring a collector.
AVELREN_INSTANCE_ID=local-instance
COLLECTOR_LEASE_TTL_SECONDS=120

# Current API runtime variables.
HOST=127.0.0.1
PORT=3000

# Push is disabled by default. Values are intentionally blank.
PUSH_ENABLED=false
# FCM_PROJECT_ID=
# PUSH_TOKEN_ACTIVE_KEY_ID=
# PUSH_TOKEN_ENCRYPTION_KEYS=
# PUSH_TOKEN_FINGERPRINT_KEY=
# PUSH_PROVIDER_TIMEOUT_MS=10000
# PUSH_WORKER_INTERVAL_MS=5000
# PUSH_WORKER_BATCH_SIZE=25
# PUSH_WORKER_CONCURRENCY=4
# PUSH_CLAIM_TTL_MS=60000
# PUSH_MAX_ATTEMPTS=8
# PUSH_RETRY_BASE_MS=1000
# PUSH_RETRY_MAX_MS=900000
