# Copy to /etc/avelren/backup/backup.env, mode 0600, owner root:root.
# Keep the Restic password file root:root mode 0400; mode 0600 is accepted only for backward compatibility.
AVELREN_RCLONE_REMOTE=private-google-drive
AVELREN_RESTIC_PASSWORD_FILE=/etc/avelren/backup/restic_password
AVELREN_RCLONE_CONFIG=/etc/avelren/backup/rclone.conf
# Host-side dump streaming timeout in seconds; accepted range: 30..7200.
AVELREN_BACKUP_TRANSFER_TIMEOUT=900
