# Copy to .env.production and replace placeholders only on the deployment host.
# Never commit .env.production or files under ./secrets/.
AVELREN_DOMAIN=api.example.invalid
ACME_EMAIL=operator@example.invalid
AVELREN_INSTANCE_ID=avelren-single-server-placeholder

POSTGRES_DB=avelren
POSTGRES_USER=avelren
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
DATABASE_URL_FILE=./secrets/database_url

# These first-start values are fixed in docker-compose.yml so an env-file
# override cannot accidentally enable unfinished production features:
# NODE_ENV=production
# AVELREN_STORAGE_MODE=postgres
# PUSH_ENABLED=false
# APP_ATTESTATION_MODE=disabled
# EXTERNAL_SOURCE_ENABLED=false
